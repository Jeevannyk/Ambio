# ── Spotify Music Player setup ────────────────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard  and log in
# 2. Click "Create app" (any name + description)
# 3. In the app's settings, under "Redirect URIs" add EXACTLY:
#        http://localhost:5173
#    (This is the default Vite dev server URL)
# 4. Tick the "Web API" checkbox, then Save
# 5. Copy the app's Client ID and paste it after the = on the line below
# 6. Restart the dev server (npm run dev) and open  http://localhost:5173
#
# Note: play / pause / skip require a Spotify PREMIUM account (Web API limit).
VITE_SPOTIFY_CLIENT_ID=

# ── LiveKit rooms setup (video calls) ─────────────────────────────────
# 1. Create a free project at https://cloud.livekit.io
# 2. Open Settings -> Keys and copy the API key, secret, and project URL
# 3. Paste them below, then run the token server:  npm run server
# These are SERVER-SIDE only — never exposed to the browser.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# Port for the token server (optional, defaults to 3001).
PORT=3001
